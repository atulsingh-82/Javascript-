
// current date and time
let now = new Date();
console.log(now)

// current date
let date = new Date();
console.log(date.toDateString());

//current time
let time = new Date();
console.log(time.toTimeString());

// get individual value

let d = new Date()
console.log(d.getFullYear());//full years
console.log(d.getMonth());//months
console.log(d.getDate());//dates
console.log(d.getDay());//days 0-6
console.log(d.getHours());//hrs
console.log(d.getMinutes());//min
console.log(d.getSeconds());
console.log(d.getMilliseconds());

console.log(d.toLocaleDateString());
console.log(d.toLocaleTimeString('default',{weekday:"long"}));

console.log(d.toLocaleString());
